<?xml version="1.0" encoding="utf-8"?>
<!-- 这是整个页面的根布局 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ChatActivity">

    <!-- 背景图片 -->
    <ImageView
        android:id="@+id/backgroundImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="center"
        android:src="@drawable/default_background"
        />

    <!-- WebRTC的Video画面 -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remoteVideoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:visibility="invisible"
        />

    <!-- 消息列表视图 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/messagesListView"
        android:layout_width="250dp"
        android:layout_height="350dp"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginLeft="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="120dp"
        android:background="@drawable/recyclerview_radius"/>

    <!-- 摄像头预览视图 -->
    <FrameLayout
        android:id="@+id/cameraFullView"
        android:layout_width="144dp"
        android:layout_height="256dp"
        android:background="@drawable/preview_radius"
        android:clipToOutline="true"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="35dp"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="15dp"
        android:visibility="invisible">
        <androidx.camera.view.PreviewView
            android:id="@+id/cameraPreview"
            android:layout_width="144dp"
            android:layout_height="256dp"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="0dp"
            android:background="@android:color/black"
            android:clipToOutline="true"
            />
        <ImageView
            android:id="@+id/switchCameraDirectionIcon"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/switch_camera"
            android:layout_marginStart="57dp"
            android:layout_marginTop="10dp"
            />
    </FrameLayout>

    <!-- 返回按钮 -->
    <ImageView
        android:id="@+id/backPageIcon"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:src="@drawable/navtalk_back"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="25dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="40dp"
        />

    <!-- 通话状态控件 -->
    <FrameLayout
        android:id="@+id/callStatusView"
        android:layout_width="80dp"
        android:layout_height="70dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="30dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <FrameLayout
            android:id="@+id/callFullIconView"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/view_radius"
            android:layout_marginTop="0dp"
            android:layout_marginStart="20dp">
            <ImageView
                android:id="@+id/callStatusIcon"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_gravity="center"
                android:src="@drawable/call_open"
                />
        </FrameLayout>
        <TextView
            android:id="@+id/callStatusText"
            android:layout_width="80dp"
            android:layout_height="20dp"
            android:layout_marginTop="45dp"
            android:textAlignment="center"
            android:text="Call"
            android:textSize="15sp"
            android:textColor="@android:color/white"
            android:gravity="center"
            />
    </FrameLayout>

    <!-- 麦克风状态控件 -->
    <FrameLayout
        android:id="@+id/microphoneStatusView"
        android:layout_width="90dp"
        android:layout_height="70dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="30dp"
        app:layout_constraintEnd_toStartOf="@+id/callStatusView"
        android:layout_marginEnd="5dp"
        android:visibility="invisible"
        >
        <FrameLayout
            android:id="@+id/microphoneFullIconView"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/view_radius"
            android:layout_marginTop="0dp"
            android:layout_marginStart="25dp">
            <ImageView
                android:id="@+id/microphoneStatusIcon"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_gravity="center"
                android:src="@drawable/micphone_opend"
                />
        </FrameLayout>
        <TextView
            android:layout_width="90dp"
            android:layout_height="20dp"
            android:layout_marginTop="45dp"
            android:textAlignment="center"
            android:text="Microphone"
            android:textSize="15sp"
            android:textColor="@android:color/white"
            android:gravity="center"
            />
    </FrameLayout>

    <!-- 摄像头状态控件 -->
    <FrameLayout
        android:id="@+id/cameraStatusView"
        android:layout_width="90dp"
        android:layout_height="70dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="30dp"
        app:layout_constraintStart_toEndOf="@+id/callStatusView"
        android:layout_marginEnd="5dp"
        android:visibility="invisible"
        >
        <FrameLayout
            android:id="@+id/cameraFullIconView"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/view_radius"
            android:layout_marginTop="0dp"
            android:layout_marginStart="25dp">
            <ImageView
                android:id="@+id/cameraStatusIcon"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_gravity="center"
                android:src="@drawable/camera_closed"
                />
        </FrameLayout>
        <TextView
            android:layout_width="90dp"
            android:layout_height="20dp"
            android:layout_marginTop="45dp"
            android:textAlignment="center"
            android:text="Camera"
            android:textSize="15sp"
            android:textColor="@android:color/white"
            android:gravity="center"
            />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>